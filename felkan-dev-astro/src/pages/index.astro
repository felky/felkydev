---
import Layout from '../layouts/Layout.astro';
---

<Layout title="felkan.dev">
	<div class="page">

		<div class="center">
			<h1 class="name">Felix<br />Gramell</h1>
      <div class="about">
        <p>software developer, check out the stuff i've made!</p>
      </div>
			<div class="project">
				<a href="https://intersections.felkan.dev" target="_blank" rel="noopener" class="project-link">intersections ↗</a>
				<span class="project-note">solve the venn-diagram</span>
      </div>
      <br/>
      <div class="contact">
        <p>contact me:</p>
			  <a href="mailto:work@felkan.dev" class="email">work@felkan.dev</a>
      </div>
		</div>

	</div>
</Layout>

<style>
	.page {
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
  }

  .contact {
    display: flex;
    flex-direction: column;
    font-size: 0.78rem;
  }

	.center {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	.name {
		font-size: clamp(4.5rem, 7vw, 4rem);
		font-weight: 700;
		line-height: 0.88;
		letter-spacing: -0.05em;
		color: var(--text);
	}

	.project {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		align-items: center;
	}

	.project-link {
		font-size: 0.78rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
		width: fit-content;
	}

	.project-link:hover { color: var(--muted); }

	.project-note {
		font-size: 0.7rem;
		color: var(--muted);
	}

	.email {
		font-size: 0.7rem;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.email:hover { color: var(--text); }
</style>
